@app.post("/save-health-profile")
def save_health_profile(profile: HealthProfile):

    bmi = round(
        profile.weight /
        ((profile.height / 100) ** 2),
        2
    )

    health_score = 50

    if profile.exercise_days >= 5:
        health_score += 20

    elif profile.exercise_days >= 3:
        health_score += 10

    if profile.sleep_hours >= 7:
        health_score += 15

    if 18.5 <= bmi <= 24.9:
        health_score += 15

    cursor.execute(
        """
        INSERT INTO health_profiles
        (
            email,
            age,
            height,
            weight,
            exercise_days,
            sleep_hours,
            bmi,
            health_score
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (
            profile.email,
            profile.age,
            profile.height,
            profile.weight,
            profile.exercise_days,
            profile.sleep_hours,
            bmi,
            health_score
        )
    )

    conn.commit()

    return {
        "BMI": bmi,
        "Health Score": health_score,
        "message": "Profile Saved"
    }
@app.get("/get-health-profile")
def get_health_profile(email: str):

    cursor.execute(
        """
        SELECT *
        FROM health_profiles
        WHERE email = ?
        ORDER BY id DESC
        LIMIT 1
        """,
        (email,)
    )

    row = cursor.fetchone()

    if not row:
        return {
            "message": "Profile Not Found"
        }

    return {

        "Email": row[1],

        "Age": row[2],

        "Height": row[3],

        "Weight": row[4],

        "Exercise Days": row[5],

        "Sleep Hours": row[6],

        "BMI": row[7],

        "Health Score": row[8]
    }
