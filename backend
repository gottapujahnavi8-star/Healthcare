import requests
OPENWEATHER_API_KEY = "6a459bd0f39d687d63e6089dd1c9c24f"


client = genai.Client(api_key=GEMINI_API_KEY)
class CommunityRequest(BaseModel):
    latitude: float
    longitude: float
@app.post("/community-health-dashboard")
def community_health_dashboard(data: CommunityRequest):

    lat = data.latitude
    lon = data.longitude

    # Weather API
    weather_url = (
        f"https://api.openweathermap.org/data/2.5/weather"
        f"?lat={lat}&lon={lon}"
        f"&appid={OPENWEATHER_API_KEY}"
        f"&units=metric"
    )

    weather = requests.get(weather_url).json()

    temperature = weather["main"]["temp"]
    humidity = weather["main"]["humidity"]
    city = weather.get("name", "Unknown")

    # Heat Risk
    if temperature >= 40:
        heatwave_risk = "Severe"
    elif temperature >= 35:
        heatwave_risk = "High"
    elif temperature >= 30:
        heatwave_risk = "Moderate"
    else:
        heatwave_risk = "Low"

    # AQI API
    aqi_url = (
        f"http://api.openweathermap.org/data/2.5/air_pollution"
        f"?lat={lat}&lon={lon}"
        f"&appid={OPENWEATHER_API_KEY}"
    )

    aqi_data = requests.get(aqi_url).json()

    aqi = aqi_data["list"][0]["main"]["aqi"]

    aqi_map = {
        1: "Good",
        2: "Fair",
        3: "Moderate",
        4: "Poor",
        5: "Very Poor"
    }

    air_quality = aqi_map.get(aqi, "Unknown")

    # Gemini AI Recommendation
    prompt = f"""
    Community Health Analysis

    City: {city}
    Temperature: {temperature}°C
    Humidity: {humidity}%
    Air Quality: {air_quality}
    Heatwave Risk: {heatwave_risk}

    Give:
    1. Community Health Status
    2. Public Health Risks
    3. Health Recommendations

    Keep response under 150 words.
    """

    response = client.models.generate_content(
        model="gemini-2.5-flash",
        contents=prompt
    )

    return {
        "City": city,
        "Temperature": temperature,
        "Humidity": humidity,
        "Air Quality": air_quality,
        "Heatwave Risk": heatwave_risk,
        "AI Recommendation": response.text
    }
