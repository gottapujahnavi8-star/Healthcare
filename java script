async function generateHealthTwin() {

    const data = {

        age: parseInt(
            document.getElementById("age").value
        ),

        bmi: parseFloat(
            localStorage.getItem("BMI") || 22
        ),

        health_score: parseInt(
            localStorage.getItem("HealthScore") || 80
        ),

        exercise_days: parseInt(
            document.getElementById(
                "exerciseDays"
            ).value
        ),

        sleep_hours: parseInt(
            document.getElementById(
                "sleepHours"
            ).value
        )
    };

    let response = await fetch(
        "http://127.0.0.1:8000/digital-health-twin",
        {
            method: "POST",

            headers: {
                "Content-Type":
                "application/json"
            },

            body: JSON.stringify(data)
        }
    );

    let result = await response.json();

    let risks = result["Predicted Risks"]
        .map(r => `<li>${r}</li>`)
        .join("");

    let recs = result["Recommendations"]
        .map(r => `<li>${r}</li>`)
        .join("");

    document.getElementById(
        "healthTwinResult"
    ).innerHTML =

    `
    <h3>Digital Health Twin Report</h3>

    <p>
    <b>Current Health Score:</b>
    ${result["Current Health Score"]}
    </p>

    <p>
    <b>Future Health Status:</b>
    ${result["Future Health Status"]}
    </p>

    <h4>Predicted Risks</h4>
    <ul>${risks}</ul>

    <h4>Recommendations</h4>
    <ul>${recs}</ul>
    `;
}
async function loadCommunityDashboard() {

    navigator.geolocation.getCurrentPosition(
        async function(position){

            const latitude =
                position.coords.latitude;

            const longitude =
                position.coords.longitude;

            let response = await fetch(
                "http://127.0.0.1:8000/community-health-dashboard",
                {
                    method:"POST",

                    headers:{
                        "Content-Type":
                        "application/json"
                    },

                    body: JSON.stringify({
                        latitude,
                        longitude
                    })
                }
            );

            let result =
                await response.json();

            document.getElementById(
                "communityResult"
            ).innerHTML =

            `
            <h3>Community Health Dashboard</h3>

            <p><b>City:</b>
            ${result.City}</p>

            <p><b>Temperature:</b>
            ${result.Temperature}°C</p>

            <p><b>Humidity:</b>
            ${result.Humidity}%</p>

            <p><b>Air Quality:</b>
            ${result["Air Quality"]}</p>

            <p><b>Heatwave Risk:</b>
            ${result["Heatwave Risk"]}</p>

            <h4>AI Recommendation</h4>

            <pre>
${result["AI Recommendation"]}
            </pre>
            `;
        }
    );
}
